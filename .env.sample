# Application
APPLICATION_NAME=celebr8lyfe-backend
NODE_ENV=dev
PORT=8000
TZ=UTC

# Database (PostgreSQL)
DB_USER=
DB_PASSWORD=
DB_DATABASE=
DB_IP=127.0.0.1
DB_PORT=5432
DB_DIALECT=postgres
DB_SSL_REQUIRED=false

# Auth
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=7d

# Optional
COOKIE_DOMAIN=localhost

# Observability (Application Insights) — leave empty in local dev to log to console
APPLICATIONINSIGHTS_CONNECTION_STRING=
